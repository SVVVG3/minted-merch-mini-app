{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["sfo1"],
  "functions": {
    "src/app/api/**/*.js": {
      "maxDuration": 30
    },
    "src/app/api/notifications/**": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/notifications/staking-reminder",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/notifications/staking-reminder",
      "schedule": "0 21 * * *"
    }
  ]
}